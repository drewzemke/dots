{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "Read(/tmp)",
      "Write(/tmp)",
      "Read(~/notes)",
      "Write(~/notes)",
      "Read(~/RSS)",
      "Write(~/RSS)",
      "Skill(read-daily)",
      "Skill(update-daily)",
      "mcp__plugin_atlassian_atlassian__fetch",
      "mcp__plugin_atlassian_atlassian__getJiraIssue",
      "mcp__plugin_atlassian_atlassian__search",
      "mcp__plugin_context7_context7__get-library-docs",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_screenshot",
      "Skill(atlassian:search-company-knowledge)",
      "mcp__plugin_atlassian_atlassian__getAccessibleAtlassianResources",
      "mcp__plugin_atlassian_atlassian__searchJiraIssuesUsingJql",
      "mcp__claude_buddy__*"
    ],
    "deny": [
      "Read(.env)",
      "Bash(git:*)",
      "Bash(jj push)",
      "Bash(jj git push)"
    ],
    "ask": [],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-6[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git:*)",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'I use jj (jujutsu) for local version control, not git. Use the jj equivalent — jj log, jj status, jj commit, jj describe, etc.' >&2; exit 2"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell'"
          },
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions notify \"Claude needs approval\"'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell done'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell working'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell working'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell done'"
          },
          {
            "type": "command",
            "command": "sh -c 'test -d .jj && jj status || exit 0'"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell error'"
          },
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions notify \"Claude hit an error\"'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions jj-worktree create'"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions jj-worktree remove'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell clear'"
          },
          {
            "type": "command",
            "command": "sh -c 'f=~/.claude/settings.json; tmp=$(mktemp); jq --indent 2 . \"$f\" > \"$tmp\" && cp \"$tmp\" \"$f\" && rm \"$tmp\"'",
            "statusMessage": "normalizing settings.json indentation"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": false,
    "code-simplifier@claude-plugins-official": false
  },
  "spinnerTipsEnabled": false,
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-ansi",
  "fileCheckpointingEnabled": false,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754080118645
  },
  "skipAutoPermissionPrompt": true
}
