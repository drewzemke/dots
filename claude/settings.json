{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "WebFetch",
      "WebSearch",
      "Write(/tmp)",
      "Read(/tmp)",
      "Read(~/notes)",
      "Write(~/notes)",
      "Skill(read-daily)",
      "Skill(update-daily)",
      "mcp__plugin_atlassian_atlassian__fetch",
      "mcp__plugin_atlassian_atlassian__getJiraIssue",
      "mcp__plugin_atlassian_atlassian__search",
      "mcp__plugin_context7_context7__get-library-docs",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_figma_figma__get_design_context",
      "mcp__plugin_figma_figma__get_metadata",
      "mcp__plugin_figma_figma__get_screenshot"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell init'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell'"
          },
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions notify \"Claude is ready!\"'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell clear'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell clear'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'test -d .jj && jj status || exit 0'"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions jj-worktree create'"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions jj-worktree remove'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nu -c 'use ~/dots/nushell/functions; functions tab-bell clear'"
          },
          {
            "type": "command",
            "command": "sh -c 'f=~/.claude/settings.json; tmp=$(mktemp); jq --indent 2 . \"$f\" > \"$tmp\" && cp \"$tmp\" \"$f\" && rm \"$tmp\"'",
            "statusMessage": "normalizing settings.json indentation"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "nu -c \"use ~/dots/nushell/modules/claude-statusline.nu; claude-statusline\""
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "syntaxHighlightingDisabled": false,
  "alwaysThinkingEnabled": true,
  "autoUpdatesChannel": "latest",
  "voiceEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754080118645
  }
}
